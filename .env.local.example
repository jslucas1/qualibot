# ─────────────────────────────────────────────
# Database (MySQL)
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
# ─────────────────────────────────────────────
DATABASE_URL="mysql://root:password@localhost:3306/qualibot"

# ─────────────────────────────────────────────
# NextAuth
# Generate AUTH_SECRET with: npx auth secret
# ─────────────────────────────────────────────
AUTH_SECRET="generate-with-npx-auth-secret"
AUTH_URL="http://localhost:3000"

# ─────────────────────────────────────────────
# Resend — used for both magic-link auth AND participant token delivery
# Get from https://resend.com
# AUTH_RESEND_KEY is read automatically by next-auth/providers/resend
# ─────────────────────────────────────────────
AUTH_RESEND_KEY="re_..."
AUTH_RESEND_FROM="noreply@yourdomain.com"

# ─────────────────────────────────────────────
# Anthropic Claude API
# Get from https://console.anthropic.com
# ─────────────────────────────────────────────
ANTHROPIC_API_KEY="sk-ant-..."

# ─────────────────────────────────────────────
# Pinecone (RAG vector database)
# Get from https://app.pinecone.io
# ─────────────────────────────────────────────
PINECONE_API_KEY="..."
PINECONE_INDEX_NAME="qualibot-kb"
PINECONE_ENVIRONMENT="..."

# ─────────────────────────────────────────────
# App
# ─────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Participant token expiry in hours (default: 72)
PARTICIPANT_TOKEN_EXPIRY_HOURS="72"